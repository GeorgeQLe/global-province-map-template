{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/global-province-map/location-split-request.schema.json",
  "title": "M23 Targeted Location Split Request",
  "type": "object",
  "required": ["request_id", "operation", "failed_paintability_test", "proposed_geometry", "sources", "license_lineage", "confidence", "affected_dates", "target_fabric_revision"],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "operation": {"enum": ["refine_h3", "split_by_boundary"]},
    "failed_paintability_test": {"type": "string", "minLength": 1},
    "proposed_geometry": {"type": "object"},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "license_lineage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "confidence": {"type": ["string", "number"]},
    "affected_dates": {"type": "array", "items": {"type": "string"}},
    "target_fabric_revision": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
