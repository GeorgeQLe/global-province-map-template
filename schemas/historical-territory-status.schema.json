{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://global-province-map-template.invalid/schemas/historical-territory-status.schema.json",
  "title": "Historical territory and typed status rows",
  "type": "object",
  "required": ["schema_version", "start_date", "components", "political_units", "provinces", "statuses"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "start_date": {"type": "string", "format": "date"},
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["territory_component_id", "political_unit_id", "geometry"],
        "properties": {
          "territory_component_id": {"type": "string", "minLength": 1},
          "political_unit_id": {"type": "string", "minLength": 1},
          "province_id": {"type": "string", "minLength": 1},
          "geometry": {"$ref": "#/$defs/polygonGeometry"},
          "historically_required": {"type": "boolean", "default": true},
          "minimum_area_merge_exempt": {"const": true},
          "evidence_ids": {"$ref": "#/$defs/nonEmptyIds"}
        },
        "additionalProperties": true
      }
    },
    "political_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["political_unit_id", "territory_component_ids", "documented_status"],
        "properties": {
          "political_unit_id": {"type": "string", "minLength": 1},
          "territory_component_ids": {"$ref": "#/$defs/nonEmptyIds"},
          "documented_status": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "provinces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["province_id", "territory_component_ids"],
        "properties": {
          "province_id": {"type": "string", "minLength": 1},
          "territory_component_ids": {"$ref": "#/$defs/nonEmptyIds"},
          "shared_administrative_unit_evidence_ids": {"$ref": "#/$defs/nonEmptyIds"},
          "full_status_match": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subject_id", "relationship", "actor_political_unit_id", "valid_from", "valid_to", "evidence_ids"],
        "properties": {
          "subject_id": {"type": "string", "minLength": 1},
          "relationship": {
            "enum": ["sovereign", "owner", "controller", "protector", "co-administrator", "occupier", "mandate-authority", "lessee", "claimant"]
          },
          "actor_political_unit_id": {"type": "string", "minLength": 1},
          "valid_from": {"type": "string", "format": "date"},
          "valid_to": {"type": "string", "format": "date"},
          "evidence_ids": {"$ref": "#/$defs/nonEmptyIds"},
          "certainty": {"enum": ["documented", "disputed", "uncertain"]}
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "nonEmptyIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "polygonGeometry": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {"enum": ["Polygon", "MultiPolygon"]},
        "coordinates": {"type": "array", "minItems": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
