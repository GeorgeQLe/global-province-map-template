{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://example.invalid/global-province-map/historical-boundary-registry.schema.json", "title": "M24 Dated Historical-Boundary Registry", "type": "object",
  "required": ["schema_version", "document_type", "artifact_version", "pass_id", "start_date", "type", "features"],
  "properties": {"schema_version": {"enum": ["0.1.0", "0.2.0"]}, "document_type": {"const": "historical_boundary_registry"}, "artifact_version": {"type": "string", "minLength": 1}, "pass_id": {"type": "string", "minLength": 1}, "start_date": {"type": "string", "format": "date"}, "type": {"const": "FeatureCollection"},
    "features": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["type", "geometry", "properties"], "properties": {"type": {"const": "Feature"}, "geometry": {"type": "object"}, "properties": {"type": "object", "required": ["feature_id", "geometry_revision", "valid_from", "valid_to", "date_precision", "semantics", "side_polity_ids", "source_ids", "license_lineage", "confidence", "uncertainty_notes", "classification", "geographic_scope", "start_date_programs"], "properties": {
      "feature_id": {"type": "string", "minLength": 1}, "geometry_revision": {"type": "string", "minLength": 1}, "valid_from": {"$ref": "#/$defs/dateish"}, "valid_to": {"$ref": "#/$defs/dateish"}, "date_precision": {"enum": ["day", "month", "year", "decade", "circa", "unknown"]}, "semantics": {"type": "string", "minLength": 1}, "side_polity_ids": {"type": "object", "required": ["left", "right"], "properties": {"left": {"type": "string", "minLength": 1}, "right": {"type": "string", "minLength": 1}}, "additionalProperties": false}, "source_ids": {"$ref": "#/$defs/strings"}, "license_lineage": {"$ref": "#/$defs/strings"}, "confidence": {"type": "string", "minLength": 1}, "uncertainty_notes": {"type": "string", "minLength": 1}, "classification": {"enum": ["hard_constraint", "soft_evidence"]}, "geographic_scope": {"type": "string", "minLength": 1}, "start_date_programs": {"$ref": "#/$defs/strings"},
      "derived_geometry_artifact_id": {"type": "string", "minLength": 1}, "error_budget_km": {"type": "number", "minimum": 0},
      "georeferencing": {"$ref": "#/$defs/georeferencing"}
    }, "additionalProperties": false}}, "additionalProperties": false}}
  }, "$defs": {
    "strings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "dateish": {"type": ["string", "null"], "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"},
    "georeferencing": {"type": "object", "required": ["transform_method", "crs", "control_points", "residual_error_km", "digitizer", "reviewer", "source_feature_reference"], "properties": {
      "transform_method": {"type": "string", "minLength": 1}, "crs": {"type": "string", "minLength": 1},
      "control_points": {"type": "array", "minItems": 3, "items": {"type": "object"}}, "residual_error_km": {"type": "number", "minimum": 0},
      "digitizer": {"type": "string", "minLength": 1}, "reviewer": {"type": "string", "minLength": 1},
      "source_feature_reference": {"type": "string", "minLength": 1}
    }, "additionalProperties": false}
  },
  "allOf": [{"if": {"properties": {"schema_version": {"const": "0.2.0"}}, "required": ["schema_version"]}, "then": {"properties": {
