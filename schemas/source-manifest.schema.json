{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/global-province-map/source-manifest.schema.json",
  "title": "Global Province Map Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_type", "build", "sources"],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "manifest_type": {
      "type": "string",
      "enum": ["planned", "build"]
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "generated_at", "generator_version"],
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "minLength": 1 },
        "generator_version": { "type": "string", "minLength": 1 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_record" }
    }
  },
  "$defs": {
    "nullable_string": {
      "type": ["string", "null"]
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "source_url",
        "access_date",
        "version",
        "original_format",
        "checksum",
        "license",
        "attribution_text",
        "default_build",
        "optional",
        "isolated",
        "restricted",
        "enabled",
        "layers",
        "artifacts",
        "transformation_steps",
        "downstream_files"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["planned", "downloaded", "processed", "excluded"] },
        "source_url": { "$ref": "#/$defs/nullable_string" },
        "access_date": { "$ref": "#/$defs/nullable_string" },
        "version": { "$ref": "#/$defs/nullable_string" },
        "original_format": { "$ref": "#/$defs/nullable_string" },
        "checksum": { "$ref": "#/$defs/nullable_string" },
        "license": { "type": "string", "minLength": 1 },
        "attribution_text": { "type": "string", "minLength": 1 },
        "default_build": { "type": "boolean" },
        "optional": { "type": "boolean" },
        "isolated": { "type": "boolean" },
        "restricted": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "layers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_record" }
        },
        "transformation_steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "downstream_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifact_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer_id",
        "status",
        "url",
        "path",
        "access_date",
        "version",
        "original_format",
        "bytes",
        "checksum"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "layer_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["planned", "downloaded", "existing"] },
        "url": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "access_date": { "$ref": "#/$defs/nullable_string" },
        "version": { "$ref": "#/$defs/nullable_string" },
        "original_format": { "$ref": "#/$defs/nullable_string" },
        "bytes": { "type": ["integer", "null"], "minimum": 0 },
        "checksum": { "$ref": "#/$defs/nullable_string" }
      }
    }
  }
}
