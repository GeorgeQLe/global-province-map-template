{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://example.invalid/global-province-map/start-date-source-manifest.schema.json", "title": "M24 Research Source Manifest", "type": "object",
  "required": ["schema_version", "document_type", "artifact_version", "pass_id", "start_date", "sources", "conflict_resolution_notes"],
  "properties": {"schema_version": {"enum": ["0.1.0", "0.2.0"]}, "document_type": {"const": "start_date_source_manifest"}, "artifact_version": {"type": "string", "minLength": 1}, "pass_id": {"type": "string", "minLength": 1}, "start_date": {"type": "string", "format": "date"},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["source_id", "citation", "url", "access_date", "version", "license", "checksum", "transformations", "review_status"], "properties": {
      "source_id": {"type": "string", "minLength": 1}, "citation": {"type": "string", "minLength": 1}, "url": {"anyOf": [{"type": "string", "format": "uri"}, {"type": "null"}]}, "access_date": {"anyOf": [{"type": "string", "format": "date"}, {"type": "null"}]}, "version": {"type": ["string", "null"]}, "license": {"type": "string", "minLength": 1}, "checksum": {"anyOf": [{"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}, {"type": "null"}]}, "transformations": {"type": "array", "items": {"type": "string", "minLength": 1}}, "review_status": {"enum": ["planned", "reviewed", "rejected"]},
      "source_type": {"enum": ["academic", "primary", "corroborating", "soft_corroboration", "negative_control"]},
      "valid_from": {"$ref": "#/$defs/dateish"}, "valid_to": {"$ref": "#/$defs/dateish"},
      "independence_group": {"type": "string", "minLength": 1},
      "derived_artifacts": {"type": "array", "items": {"$ref": "#/$defs/derivedArtifact"}}
    }, "additionalProperties": false}}, "conflict_resolution_notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "dateish": {"type": ["string", "null"], "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"},
    "derivedArtifact": {"type": "object", "required": ["artifact_id", "role", "path", "sha256", "media_type"], "properties": {
      "artifact_id": {"type": "string", "minLength": 1}, "role": {"type": "string", "minLength": 1},
      "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
      "media_type": {"type": "string", "minLength": 1}
    }, "additionalProperties": false}
  },
  "allOf": [{"if": {"properties": {"schema_version": {"const": "0.2.0"}}, "required": ["schema_version"]}, "then": {"properties": {
    "sources": {"items": {"required": ["source_type", "valid_from", "valid_to", "independence_group", "derived_artifacts"]}}
  }}}],
  "additionalProperties": false
}
