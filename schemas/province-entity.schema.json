{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/global-province-map/province-entity.schema.json",
  "title": "Global Province Map Province Entity",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "geometry", "properties"],
  "properties": {
    "type": { "const": "Feature" },
    "geometry": {
      "type": "object",
      "description": "GeoJSON Polygon or MultiPolygon geometry."
    },
    "properties": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "province_id",
        "display_name",
        "kind",
        "parent_region_id",
        "parent_country_id",
        "area_sq_km",
        "estimated_population",
        "terrain_class",
        "coastal",
        "island",
        "source_lineage",
        "license_lineage"
      ],
      "properties": {
        "province_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["land", "sea", "lake"] },
        "parent_region_id": { "type": ["string", "null"] },
        "parent_country_id": { "type": ["string", "null"] },
        "parent_area_id": {
          "type": ["string", "null"],
          "description": "M21 hierarchy: owning area (clustered admin-1 group)."
        },
        "parent_geo_region_id": {
          "type": ["string", "null"],
          "description": "M21 hierarchy: owning geographic region (distinct from parent_region_id, which stays the source admin-1 code)."
        },
        "parent_superregion_id": {
          "type": ["string", "null"],
          "description": "M21 hierarchy: owning superregion (continent-level)."
        },
        "geometry_repaired": {
          "type": "boolean",
          "description": "True when the source geometry was invalid and repaired with make_valid on ingest."
        },
        "area_sq_km": { "type": "number", "minimum": 0 },
        "estimated_population": { "type": ["number", "null"], "minimum": 0 },
        "terrain_class": { "type": ["string", "null"] },
        "coastal": { "type": "boolean" },
        "island": { "type": "boolean" },
        "sea_class": {
          "type": "string",
          "enum": ["coastal", "ocean"],
          "description": "M6 sea-zone class when kind is sea."
        },
        "parent_land_province_id": {
          "type": ["string", "null"],
          "description": "Coastal sea zone parent land province for port links."
        },
        "sea_zone_strategy": { "type": "string", "minLength": 1 },
        "ocean_grid_col": { "type": "integer", "minimum": 0 },
        "ocean_grid_row": { "type": "integer", "minimum": 0 },
        "settlement_count": { "type": "integer", "minimum": 0 },
        "population_estimation_method": {
          "type": "string",
          "enum": [
            "unavailable",
            "population-point-sum",
            "population-raster-cell-sum",
            "settlement-population-sum"
          ]
        },
        "refinement_parent_id": { "type": "string", "minLength": 1 },
        "refinement_strategy": {
          "type": "string",
          "enum": [
            "area-weighted-voronoi",
            "population-weighted-voronoi",
            "source-geometry-preserved"
          ]
        },
        "refinement_skipped_reason": {
          "type": "string",
          "enum": ["invalid-source-geometry"]
        },
        "refinement_part_index": { "type": "integer", "minimum": 1 },
        "refinement_part_count": { "type": "integer", "minimum": 1 },
        "source_lineage": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "license_lineage": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
