{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://example.invalid/global-province-map/start-date-location-assignments.schema.json", "title": "M24 Location Assignments and Targeted Splits", "type": "object",
  "required": ["schema_version", "document_type", "artifact_version", "pass_id", "start_date", "fabric_revision", "aggregation_revision", "aggregation_profile", "geometry_revision", "expected_province_count", "fabric_sidecars", "assignments", "targeted_split_requests"],
  "properties": {"schema_version": {"enum": ["0.1.0", "0.2.0"]}, "document_type": {"const": "start_date_location_assignments"}, "artifact_version": {"type": "string", "minLength": 1}, "pass_id": {"type": "string", "minLength": 1}, "start_date": {"type": "string", "format": "date"}, "fabric_revision": {"type": "string", "minLength": 1}, "aggregation_revision": {"type": "string", "minLength": 1}, "aggregation_profile": {"type": "string", "minLength": 1}, "geometry_revision": {"type": "string", "minLength": 1}, "expected_province_count": {"type": "integer", "minimum": 1},
    "fabric_sidecars": {"type": "object", "required": ["fabric_manifest", "locations", "lineage", "province_membership"], "properties": {"fabric_manifest": {"$ref": "#/$defs/sidecar"}, "locations": {"$ref": "#/$defs/sidecar"}, "lineage": {"$ref": "#/$defs/sidecar"}, "province_membership": {"$ref": "#/$defs/sidecar"}}, "additionalProperties": false},
    "constraint_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "release_sidecars": {"type": "object", "required": ["aggregation_manifest", "adjacency"], "properties": {"aggregation_manifest": {"$ref": "#/$defs/sidecar"}, "adjacency": {"$ref": "#/$defs/sidecar"}}, "additionalProperties": false},
    "assignments": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["assignment_id", "location_ids", "province_id", "polity_ids", "uncertainty", "source_ids", "notes"], "properties": {"assignment_id": {"type": "string", "minLength": 1}, "location_ids": {"$ref": "#/$defs/nonemptyStrings"}, "province_id": {"type": "string", "minLength": 1}, "polity_ids": {"$ref": "#/$defs/nonemptyStrings"}, "uncertainty": {"type": "number", "minimum": 0, "maximum": 1}, "source_ids": {"$ref": "#/$defs/nonemptyStrings"}, "notes": {"type": "string"},
      "region_id": {"type": "string", "minLength": 1}, "sovereign_polity_id": {"type": "string", "minLength": 1}, "owner_polity_id": {"type": "string", "minLength": 1}, "controller_polity_id": {"type": "string", "minLength": 1},
      "core_polity_ids": {"$ref": "#/$defs/strings"}, "claim_polity_ids": {"$ref": "#/$defs/strings"}, "dispute_polity_ids": {"$ref": "#/$defs/strings"}, "hierarchy": {"$ref": "#/$defs/hierarchy"}
    }, "additionalProperties": false}},
    "targeted_split_requests": {"type": "array", "items": {"type": "object", "required": ["request_id", "location_ids", "reason", "status", "source_ids"], "properties": {"request_id": {"type": "string", "minLength": 1}, "location_ids": {"$ref": "#/$defs/nonemptyStrings"}, "reason": {"type": "string", "minLength": 1}, "status": {"enum": ["requested", "accepted", "rejected", "superseded"]}, "source_ids": {"$ref": "#/$defs/nonemptyStrings"}}, "additionalProperties": false}}
  }, "$defs": {
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "nonemptyStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "sidecar": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}}, "additionalProperties": false},
    "hierarchy": {"type": "object", "required": ["area_id", "region_id", "superregion_id", "method"], "properties": {"area_id": {"type": "string", "minLength": 1}, "region_id": {"type": "string", "minLength": 1}, "superregion_id": {"type": "string", "minLength": 1}, "method": {"type": "string", "minLength": 1}}, "additionalProperties": false}
  },
  "allOf": [{"if": {"properties": {"schema_version": {"const": "0.2.0"}}, "required": ["schema_version"]}, "then": {"required": ["constraint_sha256", "release_sidecars"], "properties": {"assignments": {"items": {"required": ["region_id", "sovereign_polity_id", "owner_polity_id", "controller_polity_id", "core_polity_ids", "claim_polity_ids", "dispute_polity_ids", "hierarchy"]}}}}}],
  "additionalProperties": false
}
