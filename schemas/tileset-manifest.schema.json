{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/global-province-map/tileset-manifest.schema.json",
  "title": "Global Province Map Tileset Manifest (PMTiles)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "milestone",
    "pack_type",
    "generated_at",
    "generator_version",
    "backend",
    "layer_name",
    "pmtiles",
    "feature_count",
    "tile_count",
    "min_zoom",
    "max_zoom",
    "bounds"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "milestone": { "type": "string", "minLength": 1 },
    "pack_type": { "const": "tileset" },
    "generated_at": { "type": "string", "minLength": 1 },
    "generator_version": { "type": "string", "minLength": 1 },
    "backend": {
      "type": "string",
      "enum": ["native", "tippecanoe"]
    },
    "layer_name": { "type": "string", "minLength": 1 },
    "pmtiles": { "type": "string", "minLength": 1 },
    "feature_count": { "type": "integer", "minimum": 0 },
    "tile_count": { "type": "integer", "minimum": 0 },
    "min_zoom": { "type": "integer", "minimum": 0, "maximum": 22 },
    "max_zoom": { "type": "integer", "minimum": 0, "maximum": 22 },
    "bounds": {
      "type": "object",
      "required": ["west", "south", "east", "north"],
      "properties": {
        "west": { "type": "number" },
        "south": { "type": "number" },
        "east": { "type": "number" },
        "north": { "type": "number" }
      },
      "additionalProperties": true
    },
    "header": { "type": "object", "additionalProperties": true },
    "maplibre": { "type": "object", "additionalProperties": true },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
